# ═══════════════════════════════════════════════════════════════
# VaultSystemFx Backend - Configurazione
# ═══════════════════════════════════════════════════════════════
# Copia questo file come .env e compila i valori

# Porta server (default: 3000)
PORT=3000

# ─────────────────────────────────────────────────────────────────
# EMAIL (Gmail)
# ─────────────────────────────────────────────────────────────────
# La tua email Gmail
EMAIL_USER=tuaemail@gmail.com

# App Password di Gmail (NON la password normale!)
# Come ottenerla:
# 1. Vai su https://myaccount.google.com/security
# 2. Attiva "Verifica in 2 passaggi"
# 3. Vai su "Password per le app"
# 4. Crea una nuova password per "Posta"
# 5. Copia la password di 16 caratteri qui sotto
EMAIL_APP_PASS=xxxx xxxx xxxx xxxx

# Email dove ricevere notifiche ordini (opzionale, default: EMAIL_USER)
NOTIFY_EMAIL=tuaemail@gmail.com

# ─────────────────────────────────────────────────────────────────
# LINK DOWNLOAD
# ─────────────────────────────────────────────────────────────────
# Link per scaricare il bot (Google Drive, Dropbox, ecc.)
DOWNLOAD_LINK_STANDARD=https://www.dropbox.com/scl/fi/l5n3cysy5kyeh0525f8la/test.zip?rlkey=p49q4d2nkvjsvkssig946tn38&st=3gz0e6hp&dl=1

DOWNLOAD_LINK_STUDENT=https://www.dropbox.com/scl/fi/l5n3cysy5kyeh0525f8la/test.zip?rlkey=p49q4d2nkvjsvkssig946tn38&st=3gz0e6hp&dl=1

# ─────────────────────────────────────────────────────────────────
# SICUREZZA
# ─────────────────────────────────────────────────────────────────
# Chiave per endpoint admin (invio manuale email)
ADMIN_KEY=una_chiave_segreta_lunga_e_casuale

# ─────────────────────────────────────────────────────────────────
# PAYPAL (opzionale - per webhook)
# ─────────────────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=tuo_client_id
PAYPAL_CLIENT_SECRET=tuo_client_secret
